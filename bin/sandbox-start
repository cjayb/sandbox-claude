#!/usr/bin/env bash
# sandbox-start <name> [repo-url] [flags]
# Create a new agent container from a golden image, or restart a stopped one
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

# ── Parse args ──────────────────────────────────────────────────────
NAME=""
REPO=""
STACK="base"
BRANCH=""
FROM=""
SSH_KEY=""
SLOT=""
CPU=""
MEMORY=""
EXTRA_ENVS=()
RESTRICT_DOMAINS=""
DOMAINS_FILE=""
COPY_AZURE=""
COPY_CLAUDE=""
COPY_CLAUDE_SOURCE=""  # "profile" (curated repo profile) or "host" (~/.claude)
NO_REPO=""
ISSUE=""

# ── Helpers ──────────────────────────────────────────────────────
apply_domain_filtering() {
  local container="$1" domains_file="$2"
  local resolved_file resolved_name container_ip

  resolved_file=$(resolve_domains_file "$domains_file")
  resolved_name=$(basename "$resolved_file")

  container_ip=$(get_container_ip "$container")
  [[ -n "$container_ip" ]] || die "Could not determine container IP for domain filtering"

  setup_container_domain_filter "$container" "$resolved_file" "$container_ip"
  redirect_container_to_squid "$container_ip"
  vm_exec "iptables -I FORWARD -s '${container_ip}' -o '${OUTBOUND_IFACE}' -p udp --dport 443 -j DROP"

  ok "Domain filtering active (${resolved_name})"
}

print_connection_summary() {
  local container="$1" name="$2" status_word="$3"
  local slot stack_name ssh_p app_p alt_p

  slot=$(get_metadata "$container" "slot")
  stack_name=$(get_metadata "$container" "stack")
  ssh_p=$(ssh_port "$slot")
  app_p=$(app_port "$slot")
  alt_p=$(alt_port "$slot")

  echo ""
  ok "=== '${container}' ${status_word} ==="
  echo ""
  echo "  Slot:      ${slot}"
  echo "  Stack:     ${stack_name:-unknown}"
  if [[ "$(get_metadata "$container" "restrict-domains")" == "yes" ]]; then
    echo "  Domains:   RESTRICTED"
  else
    echo "  Domains:   open (all HTTPS allowed)"
  fi
  if [[ "$(get_metadata "$container" "copy-azure")" == "yes" ]]; then
    echo "  Azure:     host ~/.azure copied at create time (no sync back)"
  fi
  if [[ "$(get_metadata "$container" "copy-claude")" == "yes" ]]; then
    local claude_src
    claude_src=$(get_metadata "$container" "copy-claude-source")
    if [[ "$claude_src" == "host" ]]; then
      echo "  Claude:    host ~/.claude config seeded at create time (--copy-claude-host)"
    else
      echo "  Claude:    curated profile/.claude seeded at create time (--copy-claude)"
    fi
  fi
  local issue_meta
  issue_meta=$(get_metadata "$container" "issue")
  if [[ -n "$issue_meta" ]]; then
    echo "  Issue:     ${issue_meta} (ISSUE.md seeded at workspace root)"
  fi
  echo "  SSH:       ssh -o StrictHostKeyChecking=no -p ${ssh_p} ubuntu@localhost"
  echo "  VS Code:   code --remote ssh-remote+ubuntu@localhost:${ssh_p} ${WORKSPACE_DIR}"
  echo "  App:       http://localhost:${app_p}"
  echo "  Alt:       http://localhost:${alt_p}"
  echo ""
  echo "  Shell:     sandbox ${name}"
  echo "  Claude:    sandbox ${name} --claude"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --stack)            [[ -n "${2:-}" ]] || die "--stack requires a value"; STACK="$2"; shift 2 ;;
    --branch)           [[ -n "${2:-}" ]] || die "--branch requires a value"; BRANCH="$2"; shift 2 ;;
    --from)             [[ -n "${2:-}" ]] || die "--from requires a value"; FROM="$2"; shift 2 ;;
    --ssh-key)          [[ -n "${2:-}" ]] || die "--ssh-key requires a value"; SSH_KEY="$2"; shift 2 ;;
    --slot)             [[ -n "${2:-}" ]] || die "--slot requires a value"; SLOT="$2"; shift 2 ;;
    --cpu)              [[ -n "${2:-}" ]] || die "--cpu requires a value"; CPU="$2"; shift 2 ;;
    --memory)           [[ -n "${2:-}" ]] || die "--memory requires a value"; MEMORY="$2"; shift 2 ;;
    --env)              [[ -n "${2:-}" ]] || die "--env requires a value"; EXTRA_ENVS+=("$2"); shift 2 ;;
    --restrict-domains) RESTRICT_DOMAINS="yes"; shift ;;
    --domains-file)     [[ -n "${2:-}" ]] || die "--domains-file requires a value"; RESTRICT_DOMAINS="yes"; DOMAINS_FILE="$2"; shift 2 ;;
    --copy-azure)       COPY_AZURE="yes"; shift ;;
    --copy-claude)      COPY_CLAUDE="yes"; COPY_CLAUDE_SOURCE="profile"; shift ;;
    --copy-claude-host) COPY_CLAUDE="yes"; COPY_CLAUDE_SOURCE="host"; shift ;;
    --no-repo)          NO_REPO="yes"; shift ;;
    --issue)            [[ -n "${2:-}" ]] || die "--issue requires a value"; ISSUE="$2"; shift 2 ;;
    --*)                die "Unknown flag: $1" ;;
    *)
      if [[ -z "$NAME" ]]; then
        NAME="$1"
      elif [[ -z "$REPO" ]]; then
        REPO="$1"
      else
        die "Unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

[[ -n "$NAME" ]] || die "Usage: sandbox-start <name> [repo-url] [flags]"

# ── Check for existing container (restart-or-create) ──────────────
require_sandbox
CONTAINER=$(container_name "$NAME")

CONTAINER_STATE=""
if vm_exec "incus info ${CONTAINER} &>/dev/null" 2>/dev/null; then
  CONTAINER_STATE=$(vm_exec "incus info ${CONTAINER} 2>/dev/null | grep 'Status:' | awk '{print \$2}'" || true)
fi

if [[ "$CONTAINER_STATE" == "RUNNING" ]]; then
  die "Container '${CONTAINER}' is already running. Use 'sandbox ${NAME}' to connect."
fi

if [[ "$CONTAINER_STATE" == "STOPPED" ]]; then
  # ── Restart path: reconfigure in-place ────────────────────────────
  info "Restarting stopped container '${CONTAINER}'..."

  # Error on flags that can't be changed in-place
  IMMUTABLE_ERROR=""
  [[ "$STACK" != "base" ]] && IMMUTABLE_ERROR+="  --stack (cannot change stack on restart)\n"
  [[ -n "$FROM" ]]         && IMMUTABLE_ERROR+="  --from (cannot change source on restart)\n"
  [[ -n "$REPO" ]]         && IMMUTABLE_ERROR+="  --repo (cannot change repo on restart)\n"
  [[ -n "$BRANCH" ]]       && IMMUTABLE_ERROR+="  --branch (cannot change branch on restart)\n"
  [[ -n "$SLOT" ]]         && IMMUTABLE_ERROR+="  --slot (cannot change slot on restart)\n"
  [[ -n "$COPY_AZURE" ]]   && IMMUTABLE_ERROR+="  --copy-azure (only seeds tokens at create time; recreate to refresh)\n"
  [[ -n "$COPY_CLAUDE" ]]  && IMMUTABLE_ERROR+="  --copy-claude / --copy-claude-host (only seeds config at create time; recreate to refresh)\n"
  [[ -n "$ISSUE" ]]        && IMMUTABLE_ERROR+="  --issue (only seeds the issue at create time; recreate to refresh)\n"
  if [[ -n "$IMMUTABLE_ERROR" ]]; then
    die "Cannot change these flags on restart (destroy and recreate instead):\n${IMMUTABLE_ERROR}Use 'sandbox-stop ${NAME} --rm' first, then 'sandbox-start ${NAME} ...' to recreate."
  fi

  # Start the container
  vm_exec "incus start ${CONTAINER}"

  # Wait for networking
  wait_for_container_networking "$CONTAINER"

  # Ensure workspace directory exists (may be missing in containers from old golden images)
  vm_exec "incus exec ${CONTAINER} -- bash -c 'mkdir -p ${WORKSPACE_DIR} && chown ${SANDBOX_UID}:${SANDBOX_GID} ${WORKSPACE_DIR}'"

  # Apply reconfigurable flags if provided
  if [[ -n "$CPU" ]]; then
    info "Updating CPU limit to ${CPU}..."
    vm_exec "incus config set ${CONTAINER} limits.cpu=${CPU}"
  fi
  if [[ -n "$MEMORY" ]]; then
    info "Updating memory limit to ${MEMORY}..."
    vm_exec "incus config set ${CONTAINER} limits.memory=${MEMORY}"
  fi

  # Inject extra env vars (appends new ones to bashrc)
  if [[ ${#EXTRA_ENVS[@]} -gt 0 ]]; then
    info "Injecting environment variables..."
    inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}
  fi

  # Handle --ssh-key: replace deploy key in container and update SSH config
  if [[ -n "$SSH_KEY" ]]; then
    [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
    info "Replacing SSH key..."
    ssh_agent_cleanup "$CONTAINER"
    ssh_agent_setup "$CONTAINER" "$SSH_KEY"
  else
    # Restart SSH agent using existing key on disk
    info "Restarting SSH agent..."
    ssh_agent_restart "$CONTAINER"
  fi

  # Handle domain filtering updates
  if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
    info "Applying domain-based egress filtering..."
    apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE"
    set_metadata "$CONTAINER" "restrict-domains" "yes"
    [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
  else
    EXISTING_RESTRICT=$(get_metadata "$CONTAINER" "restrict-domains")
    if [[ "$EXISTING_RESTRICT" == "yes" ]]; then
      info "Re-applying domain filtering from saved configuration..."
      EXISTING_DOMAINS_FILE=$(get_metadata "$CONTAINER" "domains-file")
      apply_domain_filtering "$CONTAINER" "$EXISTING_DOMAINS_FILE"
    fi
  fi

  print_connection_summary "$CONTAINER" "$NAME" "restarted"
  exit 0
fi

# ── Container doesn't exist: create from scratch ──────────────────

# ── Resolve --issue ────────────────────────────────────────────────
# Resolved before container creation so a bad spec / unauth'd gh fails fast.
ISSUE_NWO=""
ISSUE_NUM=""
ISSUE_TITLE=""
ISSUE_URL=""
ISSUE_BODY_FILE=""
if [[ -n "$ISSUE" ]]; then
  require_gh
  read -r ISSUE_NWO ISSUE_NUM < <(parse_issue_spec "$ISSUE") || die "Failed to parse --issue value: '${ISSUE}'"
  info "Fetching issue ${ISSUE_NWO}#${ISSUE_NUM}..."
  ISSUE_BODY_FILE=$(mktemp -t sandbox-issue.XXXXXX)
  trap 'rm -f "${ISSUE_BODY_FILE}"' EXIT
  ISSUE_HEADER=$(gh issue view "$ISSUE_NUM" --repo "$ISSUE_NWO" --json title,url --template $'{{.title}}\t{{.url}}') \
    || die "Failed to fetch issue ${ISSUE_NWO}#${ISSUE_NUM}. Check 'gh auth status' and that the issue exists."
  ISSUE_TITLE="${ISSUE_HEADER%$'\t'*}"
  ISSUE_URL="${ISSUE_HEADER##*$'\t'}"
  gh issue view "$ISSUE_NUM" --repo "$ISSUE_NWO" --json body --jq '.body' > "$ISSUE_BODY_FILE" \
    || die "Failed to fetch issue body for ${ISSUE_NWO}#${ISSUE_NUM}."

  # --issue implies --copy-claude (curated profile) so the issue-mode snippet
  # has a CLAUDE.md to land in. Explicit --copy-claude / --copy-claude-host wins.
  if [[ -z "$COPY_CLAUDE" ]]; then
    COPY_CLAUDE="yes"
    COPY_CLAUDE_SOURCE="profile"
    info "--issue implies --copy-claude (curated profile/.claude)"
  fi

  # Derive branch from issue body if --branch wasn't passed.
  if [[ -z "$BRANCH" ]]; then
    BRANCH=$( (grep -m1 -E '^Branch:[[:space:]]*\S' "$ISSUE_BODY_FILE" || true) | sed -E 's/^Branch:[[:space:]]*//' | tr -d '[:space:]')
    if [[ -n "$BRANCH" ]]; then
      info "Branch from issue: ${BRANCH}"
    else
      BRANCH="agent/issue-${ISSUE_NUM}"
      warn "Issue has no 'Branch:' line; using auto-derived '${BRANCH}'"
    fi
  fi
fi

# ── Resolve --from ──────────────────────────────────────────────────
if [[ -n "$FROM" ]]; then
  FROM_CONTAINER=$(container_name "$FROM")

  if [[ -z "$REPO" ]]; then
    REPO=$(vm_exec "incus exec ${FROM_CONTAINER} -- git -c safe.directory=${WORKSPACE_DIR} -C ${WORKSPACE_DIR} remote get-url origin 2>/dev/null" || true)
    [[ -n "$REPO" ]] || die "Could not determine repo URL from container '${FROM_CONTAINER}'"
    info "Inherited repo: ${REPO}"
  fi

  if [[ "$STACK" == "base" ]]; then
    FROM_STACK=$(get_metadata "$FROM_CONTAINER" "stack")
    if [[ -n "$FROM_STACK" ]]; then
      STACK="$FROM_STACK"
      info "Inherited stack: ${STACK}"
    fi
  fi

  if [[ -z "$SSH_KEY" ]]; then
    FROM_KEY="${SANDBOX_KEY_DIR}/deploy_${FROM}"
    if [[ -f "$FROM_KEY" ]]; then
      # Don't reuse the key — generate a new one for this container
      info "Will generate new deploy key (not reusing from '${FROM}')"
    fi
  fi

  # Inherit domain restriction if not explicitly set
  if [[ -z "$RESTRICT_DOMAINS" ]]; then
    FROM_RESTRICT=$(get_metadata "$FROM_CONTAINER" "restrict-domains")
    if [[ "$FROM_RESTRICT" == "yes" ]]; then
      RESTRICT_DOMAINS="yes"
      info "Inherited domain restriction from '${FROM}'"
      if [[ -z "$DOMAINS_FILE" ]]; then
        FROM_DOMAINS_FILE=$(get_metadata "$FROM_CONTAINER" "domains-file")
        if [[ -n "$FROM_DOMAINS_FILE" ]]; then
          DOMAINS_FILE="$FROM_DOMAINS_FILE"
          info "Inherited domains file: ${DOMAINS_FILE}"
        fi
      fi
    fi
  fi
fi

# ── Auto-detect repo from CWD if not explicitly provided ───────────
if [[ -z "$REPO" && -z "$FROM" && "$NO_REPO" != "yes" ]]; then
  CWD_REMOTE=$(git remote get-url origin 2>/dev/null || true)
  if [[ -n "$CWD_REMOTE" ]]; then
    REPO="$CWD_REMOTE"
    info "Detected repo from current directory: ${REPO}"
    info "(pass --no-repo to create a scratch container instead)"
  fi
fi

# ── Normalize HTTPS GitHub URLs to SSH so the deploy key is usable ──
# HTTPS clones bypass ssh-agent and would prompt for credentials.
if [[ "$REPO" =~ ^https://github\.com/(.+)$ ]]; then
  REPO_PATH="${BASH_REMATCH[1]%.git}"
  REPO="git@github.com:${REPO_PATH}.git"
  info "Rewrote HTTPS URL to SSH form: ${REPO}"
fi

# ── Validate ────────────────────────────────────────────────────────
require_golden "$STACK"

# ── Auto-assign or validate slot ────────────────────────────────────
if [[ -z "$SLOT" ]]; then
  SLOT=$(next_free_slot)
  info "Auto-assigned slot: ${SLOT}"
else
  validate_slot "$SLOT"
fi

SSH_P=$(ssh_port "$SLOT")
APP_P=$(app_port "$SLOT")
ALT_P=$(alt_port "$SLOT")

# ── Deploy key (auto-generate if repo provided and no --ssh-key) ───
KEY_PATH=""
if [[ -n "$REPO" && -z "$SSH_KEY" ]]; then
  require_gh
  deploy_key_create "$NAME" "$REPO"
  KEY_PATH="${SANDBOX_KEY_DIR}/deploy_${NAME}"
elif [[ -n "$SSH_KEY" ]]; then
  [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
  KEY_PATH="$SSH_KEY"
fi

# ── Create container ────────────────────────────────────────────────
info "Creating '${CONTAINER}' from golden-${STACK}/ready (slot ${SLOT})..."

vm_exec "
  incus copy golden-${STACK}/ready ${CONTAINER}
"

# Resource limits (only if explicitly set)
if [[ -n "$CPU" ]]; then
  vm_exec "incus config set ${CONTAINER} limits.cpu=${CPU}"
fi
if [[ -n "$MEMORY" ]]; then
  vm_exec "incus config set ${CONTAINER} limits.memory=${MEMORY}"
fi

# Proxy devices for port forwarding
vm_exec "
  incus config device add ${CONTAINER} ssh-proxy proxy \
    listen=tcp:127.0.0.1:${SSH_P} connect=tcp:127.0.0.1:22

  incus config device add ${CONTAINER} app-proxy proxy \
    listen=tcp:127.0.0.1:${APP_P} connect=tcp:127.0.0.1:8080

  incus config device add ${CONTAINER} alt-proxy proxy \
    listen=tcp:127.0.0.1:${ALT_P} connect=tcp:127.0.0.1:9090
"

# Start
vm_exec "incus start ${CONTAINER}"
vm_exec "sleep 3"

# Seed AAD tokens by copying host ~/.azure into the container.
# A live bind mount would need idmapped-mount support (OrbStack lacks it) or
# raw.idmap (breaks systemd-credentials mounts), so we copy instead. Tokens
# don't sync back to the host; recreate the sandbox after rotation/expiry.
if [[ "$COPY_AZURE" == "yes" ]]; then
  HOST_AZURE_DIR="${HOME}/.azure"
  [[ -d "$HOST_AZURE_DIR" ]] || die "${HOST_AZURE_DIR} not found. Run 'az login' on the host first."
  warn "Copying host ${HOST_AZURE_DIR} into container (excluding logs) — tokens won't sync back; recreate to refresh."
  vm_exec "incus exec ${CONTAINER} -- bash -c 'rm -rf ${SANDBOX_USER_HOME}/.azure && install -d -o ${SANDBOX_UID} -g ${SANDBOX_GID} ${SANDBOX_USER_HOME}/.azure'"
  COPYFILE_DISABLE=1 tar -C "$HOST_AZURE_DIR" \
      --no-mac-metadata --no-xattrs --no-acls --no-fflags \
      --exclude='logs' --exclude='*.log' \
      --exclude='bin' --exclude='cliextensions' --exclude='commands' \
      --exclude='telemetry' --exclude='ms-*' \
      -cf - . \
    | vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
        tar -C "${SANDBOX_USER_HOME}/.azure" -xf -
fi

# Seed Claude Code config (CLAUDE.md, skills/, commands/).
# Default source: curated profile/.claude in this repo (--copy-claude).
# Escape hatch: full host ~/.claude (--copy-claude-host).
# Snapshot at create time — edits won't sync. Recreate to refresh.
if [[ "$COPY_CLAUDE" == "yes" ]]; then
  if [[ "$COPY_CLAUDE_SOURCE" == "host" ]]; then
    CLAUDE_SRC_DIR="${HOME}/.claude"
    CLAUDE_SRC_LABEL="host ${CLAUDE_SRC_DIR}"
  else
    CLAUDE_SRC_DIR="$(cd "${SCRIPT_DIR}/../profile/.claude" 2>/dev/null && pwd)"
    CLAUDE_SRC_LABEL="curated profile/.claude"
  fi
  [[ -n "$CLAUDE_SRC_DIR" && -d "$CLAUDE_SRC_DIR" ]] || die "Claude config source not found (${CLAUDE_SRC_LABEL})."
  CLAUDE_ITEMS=()
  for item in CLAUDE.md skills commands; do
    [[ -e "${CLAUDE_SRC_DIR}/${item}" ]] && CLAUDE_ITEMS+=("$item")
  done
  [[ ${#CLAUDE_ITEMS[@]} -gt 0 ]] || die "No Claude config items found in ${CLAUDE_SRC_DIR} (expected CLAUDE.md, skills, or commands)."
  warn "Copying Claude config from ${CLAUDE_SRC_LABEL} (${CLAUDE_ITEMS[*]}) into container — won't sync back; recreate to refresh."
  vm_exec "incus exec ${CONTAINER} -- bash -c 'install -d -o ${SANDBOX_UID} -g ${SANDBOX_GID} ${SANDBOX_USER_HOME}/.claude'"
  COPYFILE_DISABLE=1 tar -C "$CLAUDE_SRC_DIR" \
      --no-mac-metadata --no-xattrs --no-acls --no-fflags \
      -h -cf - "${CLAUDE_ITEMS[@]}" \
    | vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
        tar -C "${SANDBOX_USER_HOME}/.claude" -xf -

  # Pre-seed ~/.claude.json so the first launch of `claude` in the container
  # skips the theme picker and the workspace trust dialog. The bypass-permissions
  # ("YOLO") confirmation is interactive-only and not suppressed here — use
  # `claude -p` for non-interactive runs.
  CLAUDE_FIRST_START=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")
  vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
    bash -c "cat > ${SANDBOX_USER_HOME}/.claude.json" <<EOF
{
  "hasCompletedOnboarding": true,
  "firstStartTime": "${CLAUDE_FIRST_START}",
  "projects": {
    "${WORKSPACE_DIR}": {
      "hasTrustDialogAccepted": true,
      "projectOnboardingSeenCount": 1
    }
  }
}
EOF
fi

# Append the issue-mode snippet to the seeded CLAUDE.md when --issue is set.
if [[ -n "$ISSUE" ]]; then
  SNIPPET_FILE="$(cd "${SCRIPT_DIR}/../profile/.claude" 2>/dev/null && pwd)/issue-mode-snippet.md"
  [[ -f "$SNIPPET_FILE" ]] || die "Issue-mode snippet not found at ${SNIPPET_FILE}"
  info "Appending issue-mode snippet to sandbox CLAUDE.md..."
  {
    printf '\n---\n\n'
    cat "$SNIPPET_FILE"
  } | vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
        bash -c "cat >> ${SANDBOX_USER_HOME}/.claude/CLAUDE.md"
fi

# ── Host SSH key (for user SSH access) ────────────────────────────
HOST_PUBKEY=""
for keyfile in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
  if [[ -f "$keyfile" ]]; then
    HOST_PUBKEY=$(cat "$keyfile")
    break
  fi
done
if [[ -n "$HOST_PUBKEY" ]]; then
  # Inject for ubuntu user (primary SSH access)
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c "cat >> ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chmod 600 ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chown ${SANDBOX_UID}:${SANDBOX_GID} ${SANDBOX_USER_HOME}/.ssh/authorized_keys"
  # Keep root too for emergency access
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c 'cat >> /root/.ssh/authorized_keys && chmod 600 /root/.ssh/authorized_keys'
  ok "Host SSH key injected"
else
  warn "No SSH public key found (~/.ssh/id_*.pub) — SSH access requires manual key setup"
fi

# ── SSH agent ───────────────────────────────────────────────────────
if [[ -n "$KEY_PATH" ]]; then
  info "Setting up SSH agent..."
  ssh_agent_setup "$CONTAINER" "$KEY_PATH"
fi

# ── Env vars ────────────────────────────────────────────────────────
inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}

# ── Domain filtering ───────────────────────────────────────────────
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  info "Applying domain-based egress filtering..."
  apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE"
fi

# ── Store metadata ──────────────────────────────────────────────────
set_metadata "$CONTAINER" "slot" "$SLOT"
set_metadata "$CONTAINER" "stack" "$STACK"
[[ -n "$REPO" ]] && set_metadata "$CONTAINER" "repo" "$REPO"
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  set_metadata "$CONTAINER" "restrict-domains" "yes"
  [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
fi
[[ "$COPY_AZURE" == "yes" ]] && set_metadata "$CONTAINER" "copy-azure" "yes"
if [[ "$COPY_CLAUDE" == "yes" ]]; then
  set_metadata "$CONTAINER" "copy-claude" "yes"
  set_metadata "$CONTAINER" "copy-claude-source" "$COPY_CLAUDE_SOURCE"
fi
[[ -n "$ISSUE" ]] && set_metadata "$CONTAINER" "issue" "${ISSUE_NWO}#${ISSUE_NUM}"

# ── Clone repo ──────────────────────────────────────────────────────
if [[ -n "$REPO" ]]; then
  info "Cloning repository..."

  # Configure safe.directory for ubuntu user and clone as ubuntu
  vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
    bash -c "git config --global safe.directory '*' && SSH_AUTH_SOCK=/run/ssh-agent.sock git clone ${REPO} ${WORKSPACE_DIR}" \
    || die "Git clone failed. Check SSH key and repo access."

  # Switch to requested branch (checkout if it exists remotely, create if it doesn't)
  if [[ -n "$BRANCH" ]]; then
    vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
      bash -c "cd ${WORKSPACE_DIR} && git checkout ${BRANCH} 2>/dev/null || git checkout -b ${BRANCH}" \
      || die "Failed to switch to branch '${BRANCH}'"
    ok "Repository cloned (branch: ${BRANCH})"
  else
    ok "Repository cloned"
  fi
fi

# Ensure workspace directory exists for scratch containers (no repo)
if [[ -z "$REPO" ]]; then
  vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} -- \
    mkdir -p "${WORKSPACE_DIR}"
fi

# Seed ISSUE.md at the workspace root (after repo clone or workspace mkdir).
if [[ -n "$ISSUE" ]]; then
  info "Writing ISSUE.md to ${WORKSPACE_DIR}..."
  {
    printf '# %s\n\n' "$ISSUE_TITLE"
    printf 'Source: %s\n\n' "$ISSUE_URL"
    printf -- '---\n\n'
    cat "$ISSUE_BODY_FILE"
  } | vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
        bash -c "cat > ${WORKSPACE_DIR}/ISSUE.md"
  ok "Seeded issue ${ISSUE_NWO}#${ISSUE_NUM}"
fi

# ── Done ────────────────────────────────────────────────────────────
print_connection_summary "$CONTAINER" "$NAME" "ready"
